generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String                 @id @default(cuid())
  name               String
  email              String                 @unique
  password           String?
  role               Role                   @default(USER)
  school             String?
  isActive           Boolean                @default(true)
  lastActiveAt       DateTime?
  reminderTime       String?
  notificationPrefs  Json                   @default("{}")
  classId            String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  image              String?
  nis                String?                @unique
  noAbsen            Int?
  phone              String?
  gender             String?
  address            String?
  emailVerified      DateTime?
  parentPin          String?                @default("123456")
  accounts           Account[]
  sessions           Session[]
  teacherAssignments Assignment[]           @relation("TeacherAssignments")
  studentSubmissions AssignmentSubmission[] @relation("StudentSubmissions")
  teacherSchedules   ClassSchedule[]        @relation("TeacherSchedule")
  notifications      Notification[]
  operator           Operator?
  progressLogs       ProgressLog[]
  teacherSubjects    Subject[]              @relation("TeacherSubjects")
  class              Class?                 @relation("StudentClass", fields: [classId], references: [id])
  userNotes          UserNote[]             @relation("UserNotes")
  authoredNotes      UserNote[]             @relation("AuthoredNotes")
  attendances        Attendance[]
  userSubjects       UserSubject[]
  comments           Comment[]
  calendarReminders  CalendarReminder[]


  // Coach & Ekskul
  position           String?
  affiliations       String[]               @default([])
  ekskulLeader       Extracurricular[]      @relation("LeaderEkskul")
  ekskulCoach        Extracurricular[]      @relation("CoachEkskul")
  ekskulMembers      ExtracurricularMember[] @relation("StudentEkskul")
  ekskulAttendances  ExtracurricularAttendance[] @relation("StudentEkskulAttendance")
  teacherMaterials   Material[]             @relation("TeacherMaterials")
  canEditMaterials   Boolean                @default(false)
  canEditAssignments Boolean                @default(false)
  documents          Document[]
  discussionThreads  DiscussionThread[]     @relation("AuthorThreads")
  discussionReplies  DiscussionReply[]      @relation("AuthorReplies")
  
  // CBT Exams
  teacherExams       Exam[]                 @relation("TeacherExams")
  examAttempts       ExamAttempt[]          @relation("StudentExamAttempts")

  // Parent-Child Relation
  parentId           String?
  parent             User?                  @relation("ParentChild", fields: [parentId], references: [id])
  children           User[]                 @relation("ParentChild")

  // Billing & Requests
  billings              Billing[]              @relation("StudentBillings")
  absenceRequests       AbsenceRequest[]       @relation("StudentAbsenceRequests")
  reviewedRequests      AbsenceRequest[]       @relation("ReviewedRequests")

  // Custom Modules Relations
  bookCirculations      BookCirculation[]      @relation("StudentCirculations")
  studentMedical        MedicalRecord[]        @relation("StudentMedical")
  staffMedical          MedicalRecord[]        @relation("StaffMedical")
  alumniProfile         AlumniProfile?         @relation("UserAlumniProfile")
}

model UserNote {
  id        String   @id @default(cuid())
  userId    String
  authorId  String
  content   String
  type      String   @default("GENERAL")
  createdAt DateTime @default(now())
  user      User     @relation("UserNotes", fields: [userId], references: [id], onDelete: Cascade)
  author    User     @relation("AuthoredNotes", fields: [authorId], references: [id])
}

model Attendance {
  id        String           @id @default(cuid())
  userId    String
  date      DateTime         @default(now())
  status    AttendanceStatus
  notes        String?
  checkInTime  DateTime?
  checkOutTime DateTime?
  createdAt    DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

enum AttendanceStatus {
  PRESENT
  SICK
  PERMISSION
  ABSENT
}

model Class {
  id                String             @id @default(cuid())
  name              String
  school            String
  gradeYear         Int
  createdAt         DateTime           @default(now())
  assignments       Assignment[]
  schedules         ClassSchedule[]
  students          User[]             @relation("StudentClass")
  materials         Material[]
  discussionThreads DiscussionThread[]
  exams             Exam[]

  @@unique([name, school])
}

model Subject {
  id           String          @id @default(cuid())
  name         String
  color        String          @default("#0A84FF")
  icon         String          @default("BookOpen")
  description  String?
  teacherId    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  assignments  Assignment[]
  schedules    ClassSchedule[]
  teacher      User?           @relation("TeacherSubjects", fields: [teacherId], references: [id])
  topics       Topic[]
  userSubjects UserSubject[]
  materials    Material[]
  exams        Exam[]
}

model Topic {
  id             String        @id @default(cuid())
  name           String
  order          Int           @default(0)
  description    String?
  estimatedHours Int           @default(1)
  isLocked       Boolean       @default(false)
  materials      Json?         @default("[]")
  subjectId      String
  createdAt      DateTime      @default(now())
  logs           ProgressLog[]
  assignments    Assignment[]
  subject        Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model ProgressLog {
  id         String   @id @default(cuid())
  userId     String
  topicId    String
  duration   Int
  difficulty Int
  notes      String?
  loggedAt   DateTime @default(now())
  topic      Topic    @relation(fields: [topicId], references: [id])
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSubject {
  id          String  @id @default(cuid())
  userId      String
  subjectId   String
  targetHours Int     @default(10)
  subject     Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
}

model ClassSchedule {
  id        String   @id @default(cuid())
  classId   String
  subjectId String
  teacherId String
  dayOfWeek Int
  startTime String
  endTime   String
  room      String?
  meetLink  String?
  createdAt DateTime @default(now())
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id])
  teacher   User     @relation("TeacherSchedule", fields: [teacherId], references: [id])
}

model Material {
  id          String   @id @default(cuid())
  title       String
  description String
  subjectId   String
  teacherId   String
  classId     String?
  attachments Json?    @default("[]")
  status      String   @default("BELUM_DITUGASKAN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  class       Class?   @relation(fields: [classId], references: [id])
  subject     Subject  @relation(fields: [subjectId], references: [id])
  teacher     User     @relation("TeacherMaterials", fields: [teacherId], references: [id])
}

model Extracurricular {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  schedule    String?
  leaderId    String?
  coachId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  leader      User?    @relation("LeaderEkskul", fields: [leaderId], references: [id])
  coach       User?    @relation("CoachEkskul", fields: [coachId], references: [id])
  members     ExtracurricularMember[] @relation("EkskulMembers")
  sessions    ExtracurricularSession[]
}

model ExtracurricularMember {
  id                String          @id @default(cuid())
  studentId         String
  student           User            @relation("StudentEkskul", fields: [studentId], references: [id])
  extracurricularId String
  extracurricular   Extracurricular @relation("EkskulMembers", fields: [extracurricularId], references: [id])
  joinedAt          DateTime        @default(now())

  @@unique([studentId, extracurricularId])
}

model ExtracurricularSession {
  id                String          @id @default(cuid())
  extracurricularId String
  date              DateTime
  time              String
  room              String?
  material          String?
  createdAt         DateTime        @default(now())
  extracurricular   Extracurricular @relation(fields: [extracurricularId], references: [id])
  attendances       ExtracurricularAttendance[]
}

model ExtracurricularAttendance {
  id              String          @id @default(cuid())
  sessionId       String
  studentId       String
  status          AttendanceStatus
  notes           String?
  session         ExtracurricularSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student         User            @relation("StudentEkskulAttendance", fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
}

model Assignment {
  id          String                 @id @default(cuid())
  title       String
  description String
  subjectId   String
  topicId     String?
  teacherId   String
  classId     String?
  studentId   String?
  deadline    DateTime
  maxScore    Int                    @default(100)
  attachments Json?                  @default("[]")
  status      AssignmentStatus       @default(DRAFT)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  class       Class?                 @relation(fields: [classId], references: [id])
  subject     Subject                @relation(fields: [subjectId], references: [id])
  topic       Topic?                 @relation(fields: [topicId], references: [id])
  teacher     User                   @relation("TeacherAssignments", fields: [teacherId], references: [id])
  submissions AssignmentSubmission[]
  comments    Comment[]
}

model AssignmentSubmission {
  id           String     @id @default(cuid())
  assignmentId String
  studentId    String
  content      String
  attachments  Json?      @default("[]")
  score        Int?
  feedback     String?
  submittedAt  DateTime   @default(now())
  gradedAt     DateTime?
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      User       @relation("StudentSubmissions", fields: [studentId], references: [id])
  comments     Comment[]

  @@unique([assignmentId, studentId])
}

model Comment {
  id           String                @id @default(cuid())
  content      String
  authorId     String
  assignmentId String?
  submissionId String?
  createdAt    DateTime              @default(now())
  author       User                  @relation(fields: [authorId], references: [id])
  assignment   Assignment?           @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  submission   AssignmentSubmission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model Notification {
  id             String           @id @default(cuid())
  userId         String
  type           NotificationType @default(SYSTEM)
  title          String
  message        String
  read           Boolean          @default(false)
  announcementId String?
  createdAt      DateTime         @default(now())
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement   Announcement?    @relation(fields: [announcementId], references: [id], onDelete: Cascade)
}

model Announcement {
  id            String         @id @default(cuid())
  title         String
  message       String
  type          String         @default("SYSTEM")
  createdAt     DateTime       @default(now())
  notifications Notification[]
}

model Operator {
  id        String   @id @default(cuid())
  userId    String   @unique
  scope     String
  school    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Settings {
  id                  String  @id @default("global")
  appName             String  @default("EduTrack")
  school              String  @default("SMKN 13 Bandung")
  timezone            String  @default("Asia/Jakarta")
  maintenanceMode     Boolean @default(false)
  disableRegistration Boolean @default(false)
  loginMaintenance    Boolean @default(false)
  supportEmail        String?
  backupEnabled       Boolean @default(true)
  securityLog         Boolean @default(true)
  bankName            String  @default("BCA")
  bankAccount         String  @default("1234567890")
  bankAccountName     String  @default("EduTrack Academy")
  ppdbOpen            Boolean @default(true)
  enableLibrary       Boolean @default(true)
  enableSarpras       Boolean @default(true)
  enableTataUsaha     Boolean @default(true)
  enableBendahara     Boolean @default(true)
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String   @unique
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

enum Role {
  // Level Yayasan & Top Management
  SUPER_ADMIN
  KETUA_YAYASAN
  KEPALA_SEKOLAH
  
  // Level Wakil Kepala Sekolah
  WAKASEK_KURIKULUM
  WAKASEK_KESISWAAN
  WAKASEK_HUBIN
  
  // Level Operasional Akademik
  KAPROG
  KEPALA_LAB
  TATA_USAHA
  
  // Level Keuangan
  BENDAHARA_YAYASAN
  BENDAHARA_SEKOLAH
  
  // Level Panitia & Khusus
  PANITIA_PPDB
  
  // Level Pengajar
  GURU_MAPEL
  WALI_KELAS
  GURU_BK
  
  // Level Staf Penunjang
  PUSTAKAWAN
  PETUGAS_UKS
  STAF_SARPRAS
  
  // Level Klien
  SISWA
  ORANG_TUA
  ALUMNI
  
  // Legacy / Default Roles
  STUDENT
  TEACHER
  ADMIN
  COACH
  USER
  PARENT
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum NotificationType {
  ASSIGNMENT_NEW
  ASSIGNMENT_DUE
  ASSIGNMENT_GRADED
  STUDENT_LAGGING
  SYSTEM
  ACHIEVEMENT
}

model CalendarReminder {
  id        String   @id @default(cuid())
  userId    String
  title     String
  notes     String?
  date      DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Document {
  id         String     @id @default(cuid())
  title      String     @default("Untitled")
  content    String?    // JSON content storing block structure
  userId     String
  parentId   String?
  date       DateTime?  // Optional relation to a calendar date
  position   Int        @default(0) // Order position of the block/document
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent     Document?  @relation("SubDocuments", fields: [parentId], references: [id], onDelete: Cascade)
  subDocs    Document[] @relation("SubDocuments")
}

model DiscussionThread {
  id        String            @id @default(cuid())
  title     String
  content   String
  classId   String?
  authorId  String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  
  author    User              @relation("AuthorThreads", fields: [authorId], references: [id], onDelete: Cascade)
  class     Class?            @relation(fields: [classId], references: [id], onDelete: Cascade)
  replies   DiscussionReply[]
}

model DiscussionReply {
  id        String           @id @default(cuid())
  content   String
  threadId  String
  authorId  String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  thread    DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author    User             @relation("AuthorReplies", fields: [authorId], references: [id], onDelete: Cascade)
}

// ==========================================
// CBT (Computer Based Test) Models
// ==========================================

model Exam {
  id          String   @id @default(cuid())
  title       String
  description String?
  classId     String?
  subjectId   String
  teacherId   String
  startTime   DateTime
  endTime     DateTime
  durationMin Int      @default(60)
  isStrict    Boolean  @default(true) // Anti-cheat (blur detection)
  status      ExamStatus @default(DRAFT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  class       Class?   @relation(fields: [classId], references: [id])
  subject     Subject  @relation(fields: [subjectId], references: [id])
  teacher     User     @relation("TeacherExams", fields: [teacherId], references: [id])
  questions   ExamQuestion[]
  attempts    ExamAttempt[]
}

model ExamQuestion {
  id            String   @id @default(cuid())
  examId        String
  questionText  String
  type          String   @default("MULTIPLE_CHOICE")
  options       Json     @default("[]") // Array of string/objects for choices
  correctAnswer String   // The correct option
  points        Int      @default(10)
  order         Int      @default(0)

  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers       ExamAnswer[]
}

model ExamAttempt {
  id            String   @id @default(cuid())
  examId        String
  studentId     String
  startTime     DateTime @default(now())
  endTime       DateTime?
  status        AttemptStatus @default(ONGOING)
  score         Int?
  cheatWarnings Int      @default(0)

  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student       User     @relation("StudentExamAttempts", fields: [studentId], references: [id])
  answers       ExamAnswer[]

  @@unique([examId, studentId])
}

model ExamAnswer {
  id            String   @id @default(cuid())
  attemptId     String
  questionId    String
  answerText    String
  isCorrect     Boolean  @default(false)
  pointsAwarded Int      @default(0)

  attempt       ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question      ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum AttemptStatus {
  ONGOING
  COMPLETED
}

// ==========================================
// Billing & Absence Request Models
// ==========================================

enum BillingStatus {
  UNPAID
  PENDING
  PAID
}

model Billing {
  id            String   @id @default(cuid())
  studentId     String
  title         String
  description   String?
  amount        Int
  dueDate       DateTime
  status        BillingStatus @default(UNPAID)
  paymentMethod String?
  paymentDate   DateTime?
  proofUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  student       User     @relation("StudentBillings", fields: [studentId], references: [id], onDelete: Cascade)
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==========================================
// PUSTAKAWAN (Library) Models
// ==========================================

enum CirculationStatus {
  BORROWED
  RETURNED
  OVERDUE
}

model Book {
  id            String   @id @default(cuid())
  title         String
  author        String
  isbn          String?
  stock         Int      @default(1)
  coverImage    String?
  circulations  BookCirculation[]
  createdAt     DateTime @default(now())
}

model BookCirculation {
  id            String   @id @default(cuid())
  bookId        String
  studentId     String
  borrowDate    DateTime @default(now())
  dueDate       DateTime
  returnDate    DateTime?
  status        CirculationStatus @default(BORROWED)
  penalty       Int      @default(0)
  
  book          Book     @relation(fields: [bookId], references: [id])
  student       User     @relation("StudentCirculations", fields: [studentId], references: [id])
}

// ==========================================
// UKS (Medical) Models
// ==========================================

model MedicalInventory {
  id            String   @id @default(cuid())
  name          String
  stock         Int      @default(0)
  unit          String   @default("pcs")
  records       MedicalRecord[]
}

model MedicalRecord {
  id            String   @id @default(cuid())
  studentId     String
  medicineId    String?
  complaint     String
  actionTaken   String
  handledById   String
  createdAt     DateTime @default(now())

  student       User     @relation("StudentMedical", fields: [studentId], references: [id])
  handledBy     User     @relation("StaffMedical", fields: [handledById], references: [id])
  medicine      MedicalInventory? @relation(fields: [medicineId], references: [id])
}

// ==========================================
// ALUMNI (Tracer Study) Models
// ==========================================

enum AlumniStatus {
  WORKING
  STUDYING
  ENTREPRENEUR
  LOOKING_FOR_JOB
}

model AlumniProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  graduationYear Int
  currentStatus AlumniStatus @default(LOOKING_FOR_JOB)
  institution   String?
  position      String?
  
  user          User     @relation("UserAlumniProfile", fields: [userId], references: [id], onDelete: Cascade)
}

model JobPosting {
  id            String   @id @default(cuid())
  title         String
  company       String
  description   String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model AbsenceRequest {
  id            String   @id @default(cuid())
  studentId     String
  startDate     DateTime
  endDate       DateTime
  reason        AttendanceStatus 
  description   String
  attachmentUrl String?
  status        RequestStatus @default(PENDING)
  reviewedById  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  student       User     @relation("StudentAbsenceRequests", fields: [studentId], references: [id], onDelete: Cascade)
  reviewer      User?    @relation("ReviewedRequests", fields: [reviewedById], references: [id])
}
